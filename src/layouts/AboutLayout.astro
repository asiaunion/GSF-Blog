---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";

export interface Props {
  frontmatter: {
    title: string;
    sameAs?: string[];
  };
}

const { frontmatter } = Astro.props;
const { locale } = Astro.params;
const currentLang = (locale as string | undefined) || "en";

const sameAs = frontmatter.sameAs ?? [];
const authorImageUrl = new URL(
  "/assets/images/gsf-author.jpg",
  SITE.website
).href;

const aboutPageUrl = new URL(Astro.url.pathname, Astro.url).href;

const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Joseph (GSF)",
  url: SITE.profile,
  image: authorImageUrl,
  inLanguage: currentLang,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": aboutPageUrl,
  },
  ...(sameAs.length > 0 && { sameAs }),
};
---

<Layout
  title={`${frontmatter.title} | ${SITE.title}`}
  overrideJsonLd={personLd}
>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout">
    <section id="about" class="app-prose mb-28 max-w-app prose-img:border-0">
      <h1 class="text-2xl tracking-wider sm:text-3xl">{frontmatter.title}</h1>
      <slot />
    </section>
  </main>
  <Footer />
</Layout>
