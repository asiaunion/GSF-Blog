---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";

export interface Props {
  frontmatter: {
    title: string;
    sameAs?: string[];
  };
  schemaType?: "AboutPage" | "ContactPage" | "WebPage";
}

const { frontmatter, schemaType = "AboutPage" } = Astro.props;
const { locale } = Astro.params;
const currentLang = (locale as string | undefined) || "en";

const sameAs = frontmatter.sameAs ?? [];
const authorImageUrl = new URL(
  "/assets/images/gsf-author-profile.png",
  SITE.website
).href;

const pageUrl = new URL(Astro.url.pathname, Astro.url).href;

const pageLd =
  schemaType === "AboutPage"
    ? {
        "@context": "https://schema.org",
        "@type": "AboutPage",
        name: frontmatter.title,
        url: pageUrl,
        inLanguage: currentLang,
        mainEntity: {
          "@type": "Person",
          name: "Joseph (GSF)",
          url: SITE.profile,
          image: authorImageUrl,
          ...(sameAs.length > 0 && { sameAs }),
        },
      }
    : {
        "@context": "https://schema.org",
        "@type": schemaType,
        name: frontmatter.title,
        url: pageUrl,
        inLanguage: currentLang,
        mainEntityOfPage: {
          "@type": "WebPage",
          "@id": pageUrl,
        },
      };
---

<Layout
  title={`${frontmatter.title} | ${SITE.title}`}
  overrideJsonLd={pageLd}
>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout">
    <section
      id="about"
      class="app-prose mb-28 max-w-app prose-img:mx-auto prose-img:my-4 prose-img:size-28 sm:prose-img:size-32 prose-img:rounded-full prose-img:object-cover prose-img:border prose-img:border-border"
    >
      <h1 class="text-2xl tracking-wider sm:text-3xl">{frontmatter.title}</h1>
      <slot />
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* =============================================
     Career Timeline — About page only
     ============================================= */
  :global(.career-timeline) {
    position: relative;
    padding-left: 2rem;
    margin: 1.5rem 0 2rem;
  }
  :global(.career-timeline::before) {
    content: "";
    position: absolute;
    left: 0.4375rem;
    top: 0.25rem;
    bottom: 0.25rem;
    width: 2px;
    background: var(--color-border);
  }
  :global(.timeline-item) {
    position: relative;
    padding-bottom: 1.75rem;
  }
  :global(.timeline-item:last-child) { padding-bottom: 0; }
  :global(.timeline-marker) {
    position: absolute;
    left: -2rem;
    top: 0.25rem;
    width: 0.875rem;
    height: 0.875rem;
    border-radius: 50%;
    border: 2px solid var(--color-border);
    background: var(--color-background);
    z-index: 1;
  }
  :global(.timeline-item--current .timeline-marker) {
    border-color: var(--color-accent);
    background: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 20%, transparent);
  }
  :global(.timeline-content) {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--color-muted) 40%, transparent);
    transition: border-color 0.2s;
  }
  :global(.timeline-item--current .timeline-content) {
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
  }
  :global(.timeline-content:hover) { border-color: var(--color-accent); }
  :global(.timeline-period) {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }
  :global(.timeline-role) {
    font-size: 1rem;
    font-weight: 700;
    margin: 0.125rem 0 0.5rem;
    color: var(--color-foreground);
  }
  :global(.timeline-content p) {
    font-size: 0.875rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-foreground) 80%, transparent);
    margin: 0;
  }

  /* =============================================
     About Pillars — 4-column topic cards
     ============================================= */
  :global(.about-pillars) {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin: 1.5rem 0 1.5rem;
  }
  @media (max-width: 480px) {
    :global(.about-pillars) { grid-template-columns: 1fr; }
  }
  :global(.pillar-card) {
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--color-muted) 30%, transparent);
    transition: border-color 0.2s, transform 0.2s;
  }
  :global(.pillar-card:hover) {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }
  :global(.pillar-icon) {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 0.375rem;
  }
  :global(.pillar-card h4) {
    font-size: 0.875rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
    color: var(--color-foreground);
  }
  :global(.pillar-card p) {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: color-mix(in srgb, var(--color-foreground) 70%, transparent);
    margin: 0;
  }
</style>
