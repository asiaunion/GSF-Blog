---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import {
  PUBLIC_GOOGLE_SITE_VERIFICATION,
  PUBLIC_ADSENSE_PUBLISHER_ID,
} from "astro:env/client";
import { SITE } from "@/config";
import "@/styles/global.css";
import HreflangLinks from "@/components/HreflangLinks.astro";
import type { UiLang } from "@/i18n/ui";

type Props = {
  /** When set (e.g. 404 /archives), overrides `Astro.params.locale` for `<html lang>`. */
  htmlLang?: UiLang;
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
  /** Post tags → JSON-LD keywords */
  tags?: string[];
  /** Short plain-text excerpt for JSON-LD `articleBody` (e.g. frontmatter description) */
  articleBody?: string;
  /** When set, replaces default BlogPosting JSON-LD (e.g. About → Person). */
  overrideJsonLd?: Record<string, unknown>;
};

const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  description = SITE.desc,
  ogImage = SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  canonicalURL = new URL(Astro.url.pathname, Astro.url),
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
  tags = undefined,
  articleBody = undefined,
  overrideJsonLd,
  htmlLang: htmlLangProp,
} = Astro.props;

const { locale } = Astro.params;
/** Unprefixed routes = default locale (en), per astro.config i18n */
const currentLang = (htmlLangProp ?? locale ?? "en") as string;

const socialImageURL = new URL(ogImage, Astro.url);
const canonicalHref =
  typeof canonicalURL === "string" ? canonicalURL : canonicalURL.href;
const publisherLogoUrl = new URL(
  SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  Astro.url.origin
).href;

const structuredData = overrideJsonLd ?? {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: `${title}`,
  description: `${description}`,
  image: `${socialImageURL}`,
  inLanguage: currentLang,
  ...(pubDatetime && { datePublished: pubDatetime.toISOString() }),
  ...(modDatetime && { dateModified: modDatetime.toISOString() }),
  ...(articleBody &&
    articleBody.length > 0 && {
      articleBody: articleBody.slice(0, 8000),
    }),
  author: [
    {
      "@type": "Person",
      name: `${author}`,
      ...(profile && { url: profile }),
    },
  ],
  publisher: {
    "@type": "Organization",
    name: SITE.title,
    url: SITE.website.replace(/\/+$/, ""),
    logo: {
      "@type": "ImageObject",
      url: publisherLogoUrl,
    },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalHref,
  },
  ...(tags &&
    tags.length > 0 && {
      keywords: tags.join(", "),
    }),
};
---

<!doctype html>
<html
  dir={SITE.dir}
  lang={currentLang}
  class={`${scrollSmooth && "scroll-smooth"}`}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <HreflangLinks pathname={Astro.url.pathname} site={SITE.website} />
    <meta name="generator" content={Astro.generator} />

    <!-- Load Font -->
    <Font
      cssVariable="--font-google-sans-code"
      preload={[{ subset: "latin", weight: 400, style: "normal" }]}
    />

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Article Published/Modified time -->
    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <!-- Google JSON-LD Structured data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />

    <!-- Enable RSS feed auto-discovery  -->
    <!-- https://docs.astro.build/en/recipes/rss/#enabling-rss-feed-auto-discovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={new URL("rss.xml", Astro.site)}
    />

    <meta name="theme-color" content="" />

    {
      // If PUBLIC_GOOGLE_SITE_VERIFICATION is set in the environment variable,
      // include google-site-verification tag in the heading
      // Learn more: https://support.google.com/webmasters/answer/9008080#meta_tag_verification&zippy=%2Chtml-tag
      PUBLIC_GOOGLE_SITE_VERIFICATION && (
        <meta
          name="google-site-verification"
          content={PUBLIC_GOOGLE_SITE_VERIFICATION}
        />
      )
    }

    {
      PUBLIC_ADSENSE_PUBLISHER_ID && (
        <meta
          name="google-adsense-account"
          content={PUBLIC_ADSENSE_PUBLISHER_ID}
        />
      )
    }

    <ClientRouter />

    <!--
      View transitions replace body content but keep the live <html> element.
      Sync lang from the incoming document so Pagefind / i18n match the URL
      (e.g. /search/ must use lang="en", not a stale "ko" from /ko/...).
    -->
    <script is:inline>
      document.addEventListener("astro:before-swap", function (ev) {
        if (!ev || !("newDocument" in ev) || !ev.newDocument) return;
        var lang = ev.newDocument.documentElement &&
          ev.newDocument.documentElement.getAttribute("lang");
        if (lang) document.documentElement.setAttribute("lang", lang);
      });
    </script>

    <!-- Minimal inline script to prevent FOUC - sets theme immediately -->
    <script is:inline>
      (function () {
        const initialColorScheme = ""; // "light" | "dark"
        const currentTheme = localStorage.getItem("theme");

        function getPreferTheme() {
          if (currentTheme) return currentTheme;
          if (initialColorScheme) return initialColorScheme;
          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }

        const themeValue = getPreferTheme();

        // Set theme immediately to prevent flash
        document.firstElementChild?.setAttribute("data-theme", themeValue);

        // Export minimal API for external script
        window.theme = {
          themeValue: themeValue,
          getTheme: () => window.theme.themeValue,
          setTheme: val => {
            window.theme.themeValue = val;
          },
        };
      })();
    </script>
  </head>
  <body>
    <slot />

    <!-- Load full theme logic -->
    <script src="../scripts/theme.ts"></script>
  </body>
</html>
