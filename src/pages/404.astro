---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import { SITE } from "@/config";
import { defaultUiLang, getUi } from "@/i18n/ui";

const uiLang = defaultUiLang();
const L = getUi(uiLang);
---

<Layout title={`${L.notFoundTitle} | ${SITE.title}`} htmlLang={uiLang}>
  <Header uiLang={uiLang} />

  <main
    id="main-content"
    class="app-layout flex flex-1 items-center justify-center"
  >
    <div class="mb-14 flex flex-col items-center justify-center">
      <h1 class="text-9xl font-bold text-accent">404</h1>
      <span aria-hidden="true">¯\_(ツ)_/¯</span>
      <p class="mt-4 text-2xl sm:text-3xl">{L.notFoundHeading}</p>
      <LinkButton href="/" class="link-subtle my-6 text-lg">
        {L.notFoundBackHome}
      </LinkButton>
    </div>
  </main>

  <Footer uiLang={uiLang} />
</Layout>
