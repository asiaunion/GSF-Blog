---
export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    { params: { locale: "ko" } },
    { params: { locale: "ja" } },
  ];
}

const { locale } = Astro.params;
const lang = locale || "en";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog", ({ id }) => id.startsWith(`${lang}/`));

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-16 pb-12", "border-b border-border"]}>
      <div class="flex items-start justify-between mb-8">
        <h1 class="my-4 text-4xl font-extrabold sm:my-8 sm:text-6xl tracking-tight leading-tight">
          Good Samaritan<br/>Frontier
        </h1>
        <a
          target="_blank"
          href={`${locale ? `/${locale}` : ""}/rss.xml`}
          class="inline-block mt-6 sm:mt-12 bg-foreground text-background px-4 py-2 rounded-full text-sm font-medium hover:scale-105 transition-transform"
          aria-label="rss feed"
          title="RSS Feed"
        >
          Subscribe RSS
        </a>
      </div>

      <div class="w-full max-w-2xl mb-8">
        <p class="text-xl sm:text-2xl font-medium text-foreground/80 leading-relaxed tracking-wide">
          Bridging profit and purpose.
        </p>
        <p class="mt-4 text-lg text-foreground/60 leading-loose">
          A convergence of investments and business, people and technology, restoration and reinvention — shaping a new lifestyle.
        </p>
      </div>
      {
        // only display if at least one social link is enabled
        SOCIALS.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center mb-10">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Social Links:</div>
            <Socials />
          </div>
        )
      }

      <div class="w-full h-16 sm:h-24 overflow-hidden rounded shadow-sm opacity-90 transition-opacity hover:opacity-100">
        <img
          src="/assets/images/gsf-business-hero.png"
          alt="GSF Panoramic"
          class="w-full h-full object-cover object-[center_35%]"
        />
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href={`${locale ? `/${locale}` : ""}/posts/`}>
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      // Find the current locale from the html tag to set the backUrl properly
      const currentLang = document.documentElement.lang;
      sessionStorage.setItem("backUrl", currentLang === 'en' ? '/' : `/${currentLang}/`);
    }
  });
</script>
